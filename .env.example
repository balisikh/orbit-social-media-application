# Supabase: Dashboard - Project Settings - API
# "Project URL" -> NEXT_PUBLIC_SUPABASE_URL
# "anon" "public" key -> NEXT_PUBLIC_SUPABASE_ANON_KEY (never use service_role here)
#
# Copy this file to .env.local and paste real values (no quotes).
# In Supabase: Authentication -> URL configuration -> add http://localhost:PORT/auth/callback
# to Redirect URLs (PORT must match npm run dev, e.g. 3000 or 3001).
#
# After saving .env.local, restart: npm run dev

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
